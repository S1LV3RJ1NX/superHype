# Copy to backend/.env and fill in. See docs/SETUP.md for how to obtain each value.

# Public URLs
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Database and Redis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/super-hype

REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-me-to-a-random-50-plus-char-string
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
OAUTHLIB_INSECURE_TRANSPORT=1


# Access control
COMPANY_EMAIL_DOMAIN=yourcompany.com
BOOTSTRAP_ADMIN_EMAILS=you@yourcompany.com,cofounder@yourcompany.com
CORS_ORIGINS=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn
COMMUNITY_MANAGEMENT_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202606

# X (Twitter). OAuth 2.0 app from console.x.com (type Web App, Read and Write),
# redirect URI {FRONTEND_URL}/connections/x/callback. Leave empty to keep the
# X connector hidden/disabled.
X_CLIENT_ID=
X_CLIENT_SECRET=

# LLM gateway (OpenAI-compatible base URL)
LLM_GATEWAY_URL=
LLM_API_KEY=
LLM_MODEL_NAME=

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# KNOBS
# Deployment environment: "local"/"development" enables interactive docs;
# anything production-like (or leaving it unset) disables docs. Defaults to production.
ENV=local
# App session lifetime in minutes before Google re-login is required (10080 = 7 days).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

MAX_ACTIONS_PER_ACCOUNT_PER_DAY=10
MIN_SECONDS_BETWEEN_ACCOUNT_ACTIONS=90

MAX_VIDEO_BYTES=64000000

BRAND_KEYWORDS=Acme,ACME

SELF_COMMENT_MIN_SECONDS=300
SELF_COMMENT_MAX_SECONDS=3600
DISTRIBUTE_MAX_ENGAGEMENT_TARGETS=10
FOUNDER_TEAM_NAMES=Founders

# Local testing only: override the per-campaign launch stagger so notifications
# fire almost immediately. Leave both unset in production.
# STAGGER_OVERRIDE_MIN_SECONDS=1
# STAGGER_OVERRIDE_MAX_SECONDS=3

# Window for coalescing a person's assisted engagements (comment, like, self
# comment) into one Slack "mark all done" card as their targets go live.
# ENGAGEMENT_BUNDLE_DELAY_SECONDS=30

# How long after launch to re-DM anyone still not approved or not done. Defaults
# to 6 hours; drop it low for a quick local check of the reminder path.
# REMINDER_DELAY_SECONDS=21600
