# Copy to backend/.env and fill in. See SETUP.md for how to obtain each value.

# Public URLs
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Database and Redis
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/super-hype
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET=change-me-to-a-random-50-plus-char-string
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
OAUTHLIB_INSECURE_TRANSPORT=1

# Access control
COMPANY_EMAIL_DOMAIN=yourcompany.com
BOOTSTRAP_ADMIN_EMAILS=you@yourcompany.com,cofounder@yourcompany.com
CORS_ORIGINS=http://localhost:5173

# Google OAuth (Phase 1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn (Phase 2)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_API_VERSION=202606

# LLM gateway (Phase 3) - OpenAI-compatible base URL
LLM_GATEWAY_URL=
LLM_API_KEY=
LLM_MODEL_NAME=

# Slack (Phase 5)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Observability (optional)
SENTRY_DSN=
